<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      spacing="12" style="-fx-background-color: #F5F6FA;" styleClass="monitor-root">

    <padding>
        <Insets top="16" right="18" bottom="14" left="18"/>
    </padding>

    <!-- 标题栏：Pod 名称 + 状态标签 -->
    <HBox spacing="10" alignment="CENTER_LEFT"
          style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-padding: 10 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 4, 0, 0, 1);">
        <Label text="📪" style="-fx-font-size: 15px;"/>
        <TextField fx:id="podNameLabel" editable="false" styleClass="monitor-pod-name" HBox.hgrow="ALWAYS"/>
        <Label text="状态:" style="-fx-font-size: 12px; -fx-text-fill: #999; -fx-font-weight: bold;"/>
        <TextField fx:id="statusLabel" editable="false" styleClass="monitor-status-field"/>
    </HBox>

    <!-- 详情行 -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <VBox spacing="0" HBox.hgrow="ALWAYS"
              style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-padding: 9 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 4, 0, 0, 1);">
            <HBox spacing="6" alignment="CENTER_LEFT">
                <Label text="★" style="-fx-font-size: 11px; -fx-text-fill: #326CE5;"/>
                <Label text="节点" style="-fx-font-size: 11px; -fx-text-fill: #999; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="nodeLabel" editable="false" styleClass="monitor-detail-field"/>
            </HBox>
        </VBox>
        <VBox spacing="0" HBox.hgrow="ALWAYS"
              style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-padding: 9 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 4, 0, 0, 1);">
            <HBox spacing="6" alignment="CENTER_LEFT">
                <Label text="💻" style="-fx-font-size: 11px; -fx-text-fill: #34A853;"/>
                <Label text="IP" style="-fx-font-size: 11px; -fx-text-fill: #999; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="ipLabel" editable="false" styleClass="monitor-detail-field"/>
            </HBox>
        </VBox>
        <VBox spacing="0"
              style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-padding: 9 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 4, 0, 0, 1);">
            <HBox spacing="6" alignment="CENTER_LEFT">
                <Label text="🔄" style="-fx-font-size: 11px; -fx-text-fill: #E74C3C;"/>
                <Label text="重启" style="-fx-font-size: 11px; -fx-text-fill: #999; -fx-font-weight: bold;"/>
                <Region prefWidth="2"/>
                <TextField fx:id="restartLabel" editable="false" styleClass="monitor-detail-field" prefWidth="50"/>
            </HBox>
        </VBox>
    </HBox>

    <!-- 容器列表区域 -->
    <Label text="容器资源监控" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #555; -fx-padding: 2 0 0 0;"/>

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background-insets: 0;">
        <VBox fx:id="containerList" spacing="12"/>
    </ScrollPane>

    <!-- 提示信息 -->
    <Label fx:id="hintLabel" visible="false"
           style="-fx-text-fill: #AAA; -fx-font-size: 11px; -fx-padding: 0 0 2 0;"/>
</VBox>
