<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.fxmisc.richtext.CodeArea?>
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.longfor.lmk.k8slogviewer.controller.K8sLogViewerController"
            stylesheets="@/styles.css"
            styleClass="root">
    <!-- 中间和右侧使用 SplitPane -->
    <center>
        <StackPane>
        <SplitPane fx:id="splitPane" dividerPositions="0.18" SplitPane.resizableWithParent="true">
            <!-- 左侧树视图 -->
            <HBox fx:id="treePaneWrapper" spacing="0" alignment="CENTER_RIGHT">
                <!-- 左侧树视图 -->
                <VBox fx:id="treePane" spacing="8" styleClass="tree-pane" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>

                    <HBox fx:id="searchFieldWrapper" styleClass="search-field-wrapper"
                          alignment="CENTER_LEFT" spacing="0" HBox.hgrow="ALWAYS">
                        <ComboBox fx:id="statusFilterCombo" styleClass="status-filter-combo"/>
                        <Label styleClass="search-field-separator" text="|"/>
                        <TextField fx:id="searchField" promptText="搜索命名空间/Pod..."
                                   styleClass="search-field-inner" HBox.hgrow="ALWAYS"/>
                        <Button fx:id="expandAllButton" text="^" styleClass="search-inline-button"
                                onMouseClicked="#expandAllOnClick"/>
                        <Button fx:id="collapseAllButton" text="v" styleClass="search-inline-button"
                                onMouseClicked="#collapseAllOnClick"/>
                        <Button fx:id="refreshButton" text="⟳" styleClass="search-inline-button"
                                onMouseClicked="#refreshOnClick"/>
                        <ProgressIndicator fx:id="loadingIndicator" visible="false" maxWidth="18" maxHeight="18"/>
                    </HBox>

                    <StackPane VBox.vgrow="ALWAYS">
                        <TreeView fx:id="treeView" styleClass="tree-view"/>
                        <VBox fx:id="treeLoadingOverlay" styleClass="tree-loading-overlay" visible="false" mouseTransparent="false">
                            <ProgressIndicator maxWidth="32" maxHeight="32" styleClass="tree-loading-spinner"/>
                            <Label text="加载中..." styleClass="tree-loading-label"/>
                        </VBox>
                    </StackPane>
                </VBox>

            </HBox>

            <!-- 右侧日志窗口 -->
            <VBox spacing="10" styleClass="log-pane">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>

                <!-- 搜索栏 -->
                <VBox fx:id="searchBar" styleClass="search-bar">
                    <HBox spacing="6" alignment="CENTER_LEFT" styleClass="search-input-row">
                        <TextField fx:id="inlineSearchField" promptText="输入后回车添加标签..."
                                   prefWidth="250" styleClass="search-input-field"/>
                        <Button text="+" styleClass="search-add-button" onAction="#onSearchAdd"/>
                        <ToggleButton fx:id="andOrToggle" text="或" styleClass="toolbar-button"
                                      onAction="#onAndOrToggle"/>
                        <Button fx:id="findPrevButton" styleClass="search-nav-button" onAction="#findPrev"/>
                        <Button fx:id="findNextButton" styleClass="search-nav-button" onAction="#findNext"/>
                        <Label fx:id="matchCountLabel" text="0/0" styleClass="search-match-label"/>
                        <Button fx:id="searchCloseButton" styleClass="search-close-button" onAction="#closeSearch"/>
                    </HBox>
                    <FlowPane fx:id="tagContainer" hgap="6" vgap="4" styleClass="search-tags-row"/>
                </VBox>

                <VBox spacing="5">
                    <!-- 工具栏 -->
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="尾行数(回车生效):" styleClass="label-tab"/>
                        <TextField fx:id="tailField" prefWidth="70" styleClass="text-field"/>
                        <Button fx:id="searchToggleButton" onMouseClicked="#searchToggleClick" text="暂停"
                                styleClass="toolbar-button"/>
                        <Button fx:id="scrollToTopButton" text="置顶" styleClass="toolbar-button"
                                onMouseClicked="#scrollToTopClick"/>
                        <Button fx:id="scrollToBottomButton" text="置底" styleClass="toolbar-button"
                                onMouseClicked="#scrollToBottomClick"/>
                        <Button fx:id="openLogFileButton" text="打开日志" styleClass="toolbar-button"
                                onMouseClicked="#openLogFileClick"/>
                        <ToggleButton fx:id="wrapButton" styleClass="toolbar-button"
                                      onAction="#onWrapToggle"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <ComboBox fx:id="profileSwitchCombo" promptText="切换配置" prefWidth="100" styleClass="profile-switch-combo"/>
                        <HBox fx:id="namespaceFilterContainer" styleClass="tag-input-container"/>
                        <Button fx:id="settingsButton" onMouseClicked="#handleOpenSettings"
                                styleClass="settings-button"/>
                    </HBox>
                </VBox>
                <!-- 置顶日志区域 -->
                <CodeArea fx:id="headerArea" editable="false" maxHeight="50"
                          styleClass="log-header"/>
                <!-- 日志显示区域容器 -->
                <VBox fx:id="logAreaContainer" VBox.vgrow="ALWAYS">
                    <!-- 日志显示区域（运行时被 VirtualizedScrollPane 包装） -->
                    <CodeArea fx:id="logArea" editable="false" styleClass="log-area"/>
                </VBox>
            </VBox>
        </SplitPane>
        <Button fx:id="collapseTab" styleClass="collapse-tab" onMouseClicked="#toggleTreePane"/>
        </StackPane>
    </center>
</BorderPane>
