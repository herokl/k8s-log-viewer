<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/8.0.171"
      xmlns:fx="http://javafx.com/fxml/1"
      spacing="16" style="-fx-background-color: #f9f9f9; -fx-padding: 20;">

    <Label text="添加 KubeConfig 配置" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2C3E50;"/>

    <VBox spacing="10" style="-fx-border-color: #ddd; -fx-border-radius: 6; -fx-padding: 14; -fx-background-color: #fff; -fx-background-radius: 6;">
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="配置名称：" minWidth="80" style="-fx-font-size: 13px;"/>
            <TextField fx:id="addProfileNameField" HBox.hgrow="ALWAYS" promptText="如: 生产环境、测试集群..." style="-fx-font-size: 13px;"/>
        </HBox>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="文件路径：" minWidth="80" style="-fx-font-size: 13px;"/>
            <TextField fx:id="addProfilePathField" HBox.hgrow="ALWAYS" promptText="kubeconfig 文件路径" style="-fx-font-size: 13px;"/>
            <Button text="浏览..." onAction="#onBrowseKubeconfig" styleClass="profile-browse-btn"/>
        </HBox>
    </VBox>

</VBox>
